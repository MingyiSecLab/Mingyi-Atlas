{
  "name": "@mingyilab/mingyi-atlas",
  "version": "0.24.0",
  "description": "Mingyi Atlas command-line coding and security assessment agent.",
  "type": "module",
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mingyi-atlas": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./tui": {
      "import": {
        "types": "./dist/tui/index.d.ts",
        "default": "./dist/tui.js"
      },
      "require": {
        "types": "./dist/tui/index.d.ts",
        "default": "./dist/tui.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "cli": "tsx src/main.ts",
    "check": "tsc --noEmit",
    "build": "pnpm build:lib",
    "build:lib": "tsup --silent --config tsup.config.ts && node scripts/copy-builtin-skills.mjs",
    "test:run": "vitest run",
    "test:publish": "vitest run src/__tests__/analytics.test.ts src/__tests__/package-metadata.test.ts src/utils/__tests__/update-check.test.ts src/tui/components/__tests__/banner.test.ts src/tools/__tests__/detectCaptcha.test.ts src/agents/__tests__/tools.test.ts",
    "prepack": "pnpm build:lib",
    "pack:check": "pnpm pack --dry-run",
    "prepublishOnly": "pnpm check && pnpm test:publish && pnpm build:lib",
    "build:watch": "pnpm build --watch",
    "test": "vitest",
    "lint": "eslint ."
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "coding-agent",
    "security"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.83",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "@ast-grep/napi": "^0.42.0",
    "@earendil-works/pi-tui": "^0.78.0",
    "@mastra/agent-browser": "0.4.0",
    "@mastra/core": "1.45.0",
    "@mastra/duckdb": "1.5.0",
    "@mastra/fastembed": "1.2.0",
    "@mastra/libsql": "1.14.0",
    "@mastra/mcp": "1.11.0",
    "@mastra/memory": "1.21.0",
    "@mastra/observability": "1.15.0",
    "@mastra/pg": "1.14.0",
    "@mastra/schema-compat": "1.3.0",
    "@mastra/stagehand": "0.3.0",
    "@mastra/tavily": "1.1.0",
    "ai": "^6.0.176",
    "chalk": "^5.5.0",
    "cli-highlight": "^2.1.11",
    "execa": "^9.6.1",
    "fastest-levenshtein": "^1.0.16",
    "partial-json": "^0.1.7",
    "posthog-node": "^5.28.3",
    "strip-ansi": "^7.2.0",
    "tokenx": "^1.3.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "yaml": "^2.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "22.19.15",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
